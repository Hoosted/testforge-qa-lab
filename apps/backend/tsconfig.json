{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "declaration": true,
    "removeComments": false,
    "outDir": "./dist",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@testforge/shared-types": ["../../packages/shared-types/src"]
    }
  },
  "include": ["src", "prisma", "test", "vitest.config.ts"],
  "exclude": ["dist", "node_modules"]
}
